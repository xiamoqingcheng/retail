/* ======== 支付页 · 京东白色简约风 ======== */

.payment-header {
  padding: 28rpx 32rpx;
  text-align: center;
  background-color: #ffffff;
  border-bottom: 1rpx solid var(--border);
}
.header-title { font-size: 34rpx; font-weight: 700; }

.payment-content { padding: 16rpx 24rpx; }

/* 订单摘要 */
.order-summary { margin-bottom: 16rpx; padding: 24rpx; }
.summary-title {
  display: block; font-size: 30rpx; font-weight: 600;
  margin-bottom: 16rpx; padding-bottom: 12rpx;
  border-bottom: 1rpx solid var(--border); color: var(--text-title);
}
.summary-row { display: flex; justify-content: space-between; align-items: center; padding: 8rpx 0; }
.summary-label { font-size: 28rpx; color: var(--text-body); }
.summary-value { font-size: 28rpx; color: var(--text-title); }
.total-row { margin-top: 12rpx; padding-top: 12rpx; border-top: 1rpx solid var(--border); }
.total-row .summary-label { font-weight: 700; color: var(--text-title); }
.total-row .summary-value { font-size: 38rpx; font-weight: 700; }

/* 支付方式 */
.payment-methods { margin-bottom: 16rpx; padding: 20rpx; }
.methods-title {
  display: block; font-size: 28rpx; font-weight: 600;
  margin-bottom: 16rpx; padding-bottom: 12rpx;
  border-bottom: 1rpx solid var(--border); color: var(--text-title);
}

.method-item {
  display: flex; align-items: center; padding: 20rpx 12rpx;
  border: 1rpx solid var(--border); border-radius: var(--radius-sm);
  margin-bottom: 12rpx;
}
.method-item.selected { border-color: var(--brand); background-color: var(--brand-bg); }

.method-icon { width: 48rpx; height: 48rpx; margin-right: 16rpx; }

.method-info { flex: 1; }
.method-name { display: block; font-size: 28rpx; font-weight: 600; margin-bottom: 4rpx; }
.method-desc { display: block; font-size: 24rpx; color: var(--text-secondary); }

.method-check {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  border: 2rpx solid var(--border-dark);
  display: flex; align-items: center; justify-content: center;
}
.method-item.selected .method-check {
  border-color: var(--brand); background-color: var(--brand);
}
.method-item.selected .method-check::after {
  content: ''; width: 10rpx; height: 6rpx;
  border-left: 2rpx solid #fff; border-bottom: 2rpx solid #fff;
  transform: rotate(-45deg); margin-top: -1rpx;
}

/* 余额提示 */
.balance-tip {
  padding: 16rpx; background-color: #FFFBE6;
  border-radius: var(--radius-sm); margin-bottom: 16rpx;
}
.balance-tip text { font-size: 24rpx; color: #FA8C16; }

/* 空状态 */
.empty-state { padding: 100rpx 0; text-align: center; }
.empty-state text { display: block; font-size: 28rpx; color: var(--text-secondary); margin-bottom: 24rpx; }

/* 支付按钮 */
.payment-actions { padding: 24rpx 24rpx; }

.payment-btn {
  width: 100%; height: 88rpx; line-height: 88rpx;
  font-size: 32rpx; text-align: center;
  padding: 0; margin: 0;
  background-color: var(--brand);
  color: #ffffff;
  border-radius: var(--radius-sm);
  border: none;
  font-weight: 600;
}
.payment-btn[disabled] { background-color: var(--text-placeholder); color: #ffffff; }
