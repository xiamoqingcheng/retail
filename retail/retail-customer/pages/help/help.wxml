<view class="help-page">
  <view class="quick-grid">
    <view class="quick-item" bindtap="goSettings">
      <image class="quick-icon" src="/assets/icons/settings.png"></image>
      <text>系统设置</text>
    </view>
    <view class="quick-item" bindtap="goLogin">
      <image class="quick-icon" src="/assets/icons/user.png"></image>
      <text>账号登录</text>
    </view>
    <view class="quick-item" bindtap="goSearch">
      <image class="quick-icon" src="/assets/icons/search.png"></image>
      <text>商品查询</text>
    </view>
    <view class="quick-item" bindtap="goCart">
      <image class="quick-icon" src="/assets/icons/cart.png"></image>
      <text>购物车</text>
    </view>
  </view>

  <view class="section">
    <text class="section-title">常见问题</text>
    <view class="faq-card" wx:for="{{faqList}}" wx:key="question">
      <text class="faq-question">{{item.question}}</text>
      <text class="faq-answer">{{item.answer}}</text>
    </view>
  </view>

  <view class="section">
    <text class="section-title">问题反馈</text>
    <view class="feedback-card">
      <picker value="{{feedbackTypeIndex}}" range="{{feedbackTypes}}" bindchange="onTypeChange">
        <view class="picker-row">
          <text>问题类型</text>
          <text>{{feedbackTypes[feedbackTypeIndex]}} ›</text>
        </view>
      </picker>
      <input class="contact-input" value="{{feedbackContact}}" maxlength="80" placeholder="联系方式（选填）" bindinput="onContactInput" />
      <textarea class="feedback-input" value="{{feedbackContent}}" maxlength="300" placeholder="请描述遇到的问题或建议" bindinput="onFeedbackInput"></textarea>
      <view class="feedback-actions">
        <button class="outline-button" bindtap="copyDebugInfo">复制诊断</button>
        <button class="primary-button" bindtap="submitFeedback">提交反馈</button>
      </view>
    </view>
  </view>
</view>
