<view class="container">
  <view class="order-header" wx:if="{{!isCheckout}}">
    <text class="header-title">我的订单</text>
  </view>

  <view class="status-tabs" wx:if="{{!isCheckout}}">
    <view
      class="tab-item {{currentStatus === item.value ? 'active' : ''}}"
      wx:for="{{statusTabs}}"
      wx:key="value"
      bindtap="changeStatus"
      data-status="{{item.value}}"
    >
      <view class="tab-content">
        <text>{{item.label}}</text>
        <view class="tab-badge" wx:if="{{item.count > 0}}">{{item.count}}</view>
      </view>
    </view>
  </view>

  <view class="order-list" wx:if="{{orderList.length > 0 && !isCheckout}}">
    <view class="order-item card" wx:for="{{orderList}}" wx:key="id">
      <view class="order-header flex-between">
        <text class="order-id">订单号: {{item.orderId}}</text>
        <text class="order-status {{item.statusClass}}">{{item.statusText}}</text>
      </view>

      <view class="order-goods">
        <view class="goods-item" wx:for="{{item.goods}}" wx:for-item="goods" wx:key="id">
          <image class="goods-img" src="{{goods.image}}" mode="aspectFill"></image>
          <view class="goods-info">
            <text class="goods-name">{{goods.name}}</text>
            <view class="goods-bottom flex-between">
              <text class="goods-price">¥{{goods.price}}</text>
              <text class="goods-count">x{{goods.count}}</text>
            </view>
          </view>
        </view>
      </view>

      <view class="order-footer flex-between">
        <view class="order-info">
          <text class="order-time">{{item.createTime}}</text>
          <text class="order-total">合计: ¥{{item.totalPrice}}</text>
        </view>

        <view class="order-actions">
          <button class="btn-small btn-outline" wx:if="{{item.status === 'pending'}}" bindtap="cancelOrder" data-id="{{item.id}}">取消订单</button>
          <button class="btn-small btn-primary" wx:if="{{item.status === 'pending'}}" bindtap="payOrder" data-id="{{item.id}}">去支付</button>
        </view>
      </view>
    </view>
  </view>

  <view class="empty-order" wx:if="{{orderList.length === 0 && !isCheckout}}">
    <image class="empty-icon" src="/assets/icons/order-empty.png"></image>
    <text class="empty-text">暂无订单</text>
  </view>

  <view class="checkout-section" wx:if="{{isCheckout}}">
    <view class="checkout-items card">
      <view class="checkout-item" wx:for="{{checkoutItems}}" wx:key="id">
        <image class="checkout-img" src="{{item.image}}" mode="aspectFill"></image>
        <view class="checkout-info">
          <text class="checkout-name">{{item.name}}</text>
          <text class="checkout-price price">¥{{item.price}}</text>
          <text class="checkout-count">x{{item.count}}</text>
        </view>
      </view>
    </view>

    <view class="checkout-summary card">
      <view class="summary-row flex-between">
        <text>商品总额</text>
        <text>¥{{totalPrice}}</text>
      </view>
      <view class="summary-row flex-between summary-total">
        <text>应付总额</text>
        <text class="price">¥{{totalPrice}}</text>
      </view>
    </view>

    <!-- 支付方式选择 -->
    <view class="payment-methods card">
      <view class="method-title">选择支付方式</view>
      <view class="method-item {{selectedMethod === 'balance' ? 'active' : ''}}" bindtap="selectMethod" data-method="balance">
        <view class="method-info">
          <text class="method-name">余额支付</text>
          <text class="method-desc">当前余额 ¥{{currentBalance}}</text>
        </view>
        <view class="method-check {{selectedMethod === 'balance' ? 'checked' : ''}}"></view>
      </view>
      <view class="method-item {{selectedMethod === 'wechat' ? 'active' : ''}}" bindtap="selectMethod" data-method="wechat">
        <view class="method-info">
          <text class="method-name">微信支付</text>
          <text class="method-desc">使用微信支付</text>
        </view>
        <view class="method-check {{selectedMethod === 'wechat' ? 'checked' : ''}}"></view>
      </view>
    </view>

    <view class="checkout-actions">
      <button class="btn-primary checkout-btn" bindtap="confirmPayment" loading="{{isPaying}}">
        确认支付 ¥{{totalPrice}}
      </button>
      <button class="btn-outline checkout-btn" bindtap="cancelPayment">
        稍后支付
      </button>
    </view>
  </view>
</view>
