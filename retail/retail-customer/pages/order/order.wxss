/* ======== 订单页 · 京东白色简约风 ======== */

.order-header {
  padding: 28rpx 32rpx;
  text-align: center;
  background-color: #ffffff;
  border-bottom: 1rpx solid var(--border);
}
.header-title { font-size: 34rpx; font-weight: 700; }

/* Tab 栏 */
.status-tabs {
  display: flex;
  background-color: #ffffff;
  padding: 0;
  border-bottom: 1rpx solid var(--border);
}
.tab-item {
  flex: 1; text-align: center; font-size: 28rpx;
  color: var(--text-body); position: relative; padding: 20rpx 0;
}
.tab-item.active { color: var(--brand); font-weight: 700; }
.tab-item.active::after {
  content: ''; position: absolute; bottom: 0; left: 50%;
  transform: translateX(-50%);
  width: 48rpx; height: 4rpx;
  background-color: var(--brand); border-radius: 2rpx;
}
.tab-content { display: inline-flex; align-items: center; gap: 6rpx; }
.tab-badge {
  background-color: var(--brand); color: #ffffff;
  font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 20rpx;
  min-width: 30rpx; line-height: 1.2;
}

/* 订单列表 */
.order-list { padding: 16rpx 24rpx; }

.order-item {
  margin-bottom: 12rpx; padding: 20rpx;
  background: #ffffff;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border);
}
.order-header { margin-bottom: 16rpx; padding-bottom: 12rpx; border-bottom: 1rpx solid var(--border); }

.order-id { font-size: 26rpx; color: var(--text-body); }
.order-status { font-size: 26rpx; font-weight: 600; }

.status-pending { color: var(--warning); }
.status-paid { color: #FA8C16; }
.status-shipped { color: var(--brand); }
.status-completed { color: var(--success); }

.order-goods { margin-bottom: 16rpx; }
.goods-item { display: flex; margin-bottom: 12rpx; }
.goods-item:last-child { margin-bottom: 0; }

.goods-img {
  width: 120rpx; height: 120rpx;
  border-radius: var(--radius-sm); margin-right: 16rpx;
  background-color: var(--bg-page);
}

.goods-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }
.goods-name { font-size: 28rpx; font-weight: 600; color: var(--text-title); }
.goods-bottom { margin-top: auto; display: flex; justify-content: space-between; align-items: center; }
.goods-price { font-size: 28rpx; color: var(--brand); font-weight: 600; }
.goods-count { font-size: 24rpx; color: var(--text-secondary); }

.order-footer {
  padding-top: 12rpx; border-top: 1rpx solid var(--border);
  display: flex; justify-content: space-between; align-items: center;
  flex-wrap: wrap; gap: 8rpx;
}

.order-time { font-size: 24rpx; color: var(--text-secondary); }
.order-total { font-size: 28rpx; font-weight: 600; color: var(--text-title); }

.order-actions { display: flex; gap: 12rpx; }

.btn-small {
  padding: 8rpx 20rpx; font-size: 24rpx;
  border-radius: var(--radius-sm); margin: 0; line-height: 1.5;
}
.btn-outline {
  background-color: #ffffff; border: 1rpx solid var(--border);
  color: var(--text-body);
}

/* 空订单 */
.empty-order { padding: 150rpx 0; text-align: center; }
.empty-icon { width: 200rpx; height: 200rpx; margin-bottom: 24rpx; opacity: 0.45; }
.empty-text { font-size: 28rpx; color: var(--text-secondary); }

/* 结算区 */
.checkout-section { padding: 16rpx 24rpx; }
.checkout-items { margin-bottom: 16rpx; }
.checkout-item {
  display: flex; padding: 16rpx 0;
  border-bottom: 1rpx solid var(--border);
}
.checkout-item:last-child { border-bottom: none; }
.checkout-img {
  width: 120rpx; height: 120rpx; border-radius: var(--radius-sm);
  margin-right: 16rpx; background-color: var(--bg-page);
}
.checkout-info { flex: 1; }
.checkout-name { font-size: 28rpx; font-weight: 600; color: var(--text-title); margin-bottom: 8rpx; }
.checkout-price { font-size: 30rpx; }
.checkout-count { font-size: 24rpx; color: var(--text-secondary); }

.checkout-summary { margin-bottom: 16rpx; padding: 24rpx; }
.summary-row { padding: 12rpx 0; font-size: 28rpx; }
.summary-total { padding-top: 16rpx; border-top: 1rpx solid var(--border); font-weight: 700; font-size: 32rpx; }

.checkout-actions { padding: 16rpx 0; display: flex; flex-direction: column; align-items: center; gap: 12rpx; }
.checkout-btn {
  padding: 0; margin: 0; width: 88%; height: 88rpx; line-height: 88rpx;
  font-size: 32rpx; text-align: center; border-radius: var(--radius-sm);
}

/* 支付方式选择 */
.payment-methods { margin-bottom: 16rpx; padding: 20rpx; }
.method-title { font-size: 28rpx; font-weight: 600; color: var(--text-title); margin-bottom: 12rpx; }
.method-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16rpx 0; border-bottom: 1rpx solid var(--border);
}
.method-item:last-child { border-bottom: none; }
.method-item.active { color: var(--brand); }

.method-info { display: flex; flex-direction: column; gap: 4rpx; }
.method-name { font-size: 28rpx; font-weight: 500; }
.method-desc { font-size: 24rpx; color: var(--text-secondary); }

.method-check {
  width: 36rpx; height: 36rpx; border-radius: 50%;
  border: 2rpx solid var(--border-dark);
  display: flex; align-items: center; justify-content: center;
}
.method-check.checked {
  border-color: var(--brand); background-color: var(--brand);
}
.method-check.checked::after {
  content: ''; width: 10rpx; height: 6rpx;
  border-left: 2rpx solid #fff; border-bottom: 2rpx solid #fff;
  transform: rotate(-45deg); margin-top: -1rpx;
}
