.settings-page {
  min-height: 100vh;
  padding: 24rpx;
  background: var(--bg-page);
  box-sizing: border-box;
}

.status-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx;
  background: #ffffff;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
}

.status-main {
  display: flex;
  align-items: center;
  min-width: 0;
}

.status-dot {
  flex: none;
  width: 18rpx;
  height: 18rpx;
  margin-right: 18rpx;
  border-radius: 50%;
  background: var(--text-placeholder);
}

.status-idle { background: var(--text-placeholder); }
.status-checking { background: var(--warning); }
.status-success { background: var(--success); }
.status-warning { background: var(--warning); }
.status-error { background: var(--danger); }

.status-copy {
  min-width: 0;
}

.status-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-title);
}

.status-text {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  word-break: break-all;
}

.mini-action,
.row-button,
.action-button,
.full-button {
  margin: 0;
  border: none;
  border-radius: var(--radius-sm);
  background: #ffffff;
  color: var(--text-body);
  font-size: 26rpx;
  line-height: 1;
}

.mini-action::after,
.row-button::after,
.action-button::after,
.full-button::after {
  border: none;
}

.mini-action {
  flex: none;
  padding: 18rpx 28rpx;
  border: 1rpx solid var(--brand);
  color: var(--brand);
}

.section {
  margin-top: 24rpx;
}

.section-title {
  display: block;
  margin: 0 4rpx 14rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: var(--text-title);
}

.setting-card,
.setting-list {
  background: #ffffff;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-md);
}

.setting-card {
  padding: 24rpx;
}

.url-input {
  height: 84rpx;
  padding: 0 22rpx;
  border: 1rpx solid var(--border-dark);
  border-radius: var(--radius-sm);
  background: #ffffff;
  color: var(--text-title);
  font-size: 26rpx;
  box-sizing: border-box;
}

.field-hint {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: var(--text-secondary);
  word-break: break-all;
}

.button-row {
  display: flex;
  gap: 16rpx;
  margin-top: 22rpx;
}

.action-button {
  flex: 1;
  padding: 20rpx 0;
  border: 1rpx solid var(--border-dark);
}

.primary {
  border-color: var(--brand);
  background: var(--brand);
  color: #ffffff;
}

.danger {
  border-color: var(--danger);
  color: var(--danger);
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 118rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid var(--border);
}

.setting-row:last-child {
  border-bottom: none;
}

.row-copy {
  min-width: 0;
  padding-right: 20rpx;
}

.row-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-title);
}

.row-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: var(--text-secondary);
  word-break: break-all;
}

.row-button {
  flex: none;
  min-width: 112rpx;
  padding: 18rpx 22rpx;
  border: 1rpx solid var(--border-dark);
}

.diagnostics {
  padding: 6rpx 24rpx 24rpx;
}

.diagnostic-line {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  font-size: 24rpx;
  color: var(--text-secondary);
  border-bottom: 1rpx solid var(--border);
}

.diagnostic-line text:first-child {
  flex: none;
  margin-right: 24rpx;
  color: var(--text-body);
}

.diagnostic-line text:last-child {
  min-width: 0;
  text-align: right;
  word-break: break-all;
}

.full-button {
  width: 100%;
  margin-top: 22rpx;
  padding: 24rpx 0;
  border: 1rpx solid var(--brand);
  color: var(--brand);
}
