/* ======== 登录页 · 京东白色简约风 ======== */

/* 头部 — 纯白 */
.login-header {
  text-align: center;
  padding: 80rpx 40rpx 60rpx;
  background-color: #ffffff;
}

.login-logo {
  width: 140rpx; height: 140rpx;
  border-radius: 28rpx;
  margin-bottom: 20rpx;
}

.login-title {
  display: block;
  font-size: 44rpx; font-weight: 700;
  color: var(--text-title);
  margin-bottom: 12rpx;
}

.login-subtitle {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.login-main { padding: 0 48rpx; margin-bottom: 40rpx; }

.welcome-section { text-align: center; margin-bottom: 48rpx; }
.welcome-title { display: block; font-size: 36rpx; font-weight: 700; color: var(--text-title); margin-bottom: 12rpx; }
.welcome-desc { display: block; font-size: 26rpx; color: var(--text-secondary); line-height: 1.6; }

.login-button-section { display: flex; flex-direction: column; align-items: center; }

/* 微信登录 — 绿色小圆角 */
.wechat-login-btn {
  width: 100%; height: 96rpx;
  background-color: #07C160;
  border: none; border-radius: var(--radius-sm);
  display: flex; align-items: center; justify-content: center;
  box-shadow: none;
  margin-bottom: 24rpx;
}
.wechat-login-btn::after { border: none; }
.wechat-login-btn:active { opacity: 0.85; }

.wechat-icon { width: 44rpx; height: 44rpx; margin-right: 16rpx; }
.wechat-text { color: #ffffff; font-size: 32rpx; font-weight: 600; }

.login-tip { text-align: center; font-size: 22rpx; color: var(--text-placeholder); line-height: 1.8; }

.features-section { padding: 0 40rpx 40rpx; }
.features-title {
  font-size: 28rpx; font-weight: 600; color: var(--text-title);
  text-align: center; margin-bottom: 24rpx;
}
.features-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.feature-item {
  display: flex; flex-direction: column; align-items: center;
  padding: 32rpx 16rpx;
  background: #ffffff;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--border);
}
.feature-item:active { background: var(--bg-page); }
.feature-icon { width: 72rpx; height: 72rpx; margin-bottom: 16rpx; }
.feature-name { display: block; font-size: 26rpx; font-weight: 600; color: var(--text-title); margin-bottom: 6rpx; }
.feature-desc { display: block; font-size: 22rpx; color: var(--text-secondary); text-align: center; }
