/* ======== 购物车 · 京东白色简约风 ======== */

.cart-header {
  padding: 28rpx 32rpx;
  background-color: #ffffff;
  border-bottom: 1rpx solid var(--border);
}

.header-title { font-size: 34rpx; font-weight: 700; color: var(--text-title); }

.edit-btn { color: var(--brand); font-size: 28rpx; }

.cart-content { padding-bottom: 200rpx; }

/* 商品列表 */
.cart-list { padding: 20rpx 24rpx; }

.cart-item {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 0;
  position: relative;
  border-bottom: 1rpx solid var(--border);
  background: none;
  border-radius: 0;
  box-shadow: none;
  margin-bottom: 0;
}

.item-checkbox { margin-right: 20rpx; margin-top: 56rpx; }

.item-img {
  width: 180rpx; height: 180rpx;
  border-radius: var(--radius-sm);
  margin-right: 20rpx;
  background-color: var(--bg-page);
}

.item-info { flex: 1; display: flex; flex-direction: column; justify-content: space-between; }

.item-name {
  font-size: 28rpx; font-weight: 600;
  color: var(--text-title);
  margin-bottom: 8rpx;
}

.item-price { font-size: 30rpx; color: var(--brand); font-weight: 600; margin-bottom: 12rpx; }

.item-bottom { margin-top: auto; display: flex; justify-content: space-between; align-items: center; }

/* 数量控制 — 方形 */
.quantity-control {
  display: flex; align-items: center;
  border: 1rpx solid var(--border-dark);
  border-radius: 4rpx;
}
.qty-btn {
  width: 52rpx; height: 52rpx;
  text-align: center; line-height: 52rpx;
  font-size: 28rpx; color: var(--text-title);
  background: #F8F8F8;
}
.qty-value {
  width: 64rpx; text-align: center; font-size: 26rpx;
  border-left: 1rpx solid var(--border-dark);
  border-right: 1rpx solid var(--border-dark);
}

.item-total { font-size: 26rpx; color: var(--text-body); }

.delete-btn {
  position: absolute; right: 0; top: 20rpx;
  color: var(--text-secondary); font-size: 24rpx;
}

/* 底部结算栏 */
.cart-bottom {
  position: fixed; bottom: 0; left: 0; right: 0;
  padding: 20rpx 28rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #ffffff;
  border-top: 1rpx solid var(--border);
  box-shadow: none;
}

.bottom-top { margin-bottom: 16rpx; }

.select-all { display: flex; align-items: center; }
.select-all text { margin-left: 8rpx; font-size: 28rpx; }

.total-label { font-size: 28rpx; color: var(--text-body); margin-right: 8rpx; }
.total-price { font-size: 34rpx; }

.checkout-btn {
  padding: 0; margin: 0;
  width: 220rpx; height: 80rpx; line-height: 80rpx;
  font-size: 30rpx; text-align: center;
  background-color: var(--brand) !important;
  color: #fff !important;
  border-radius: var(--radius-sm);
  font-weight: 600;
  box-shadow: none;
}

/* 空购物车 */
.empty-cart { padding: 150rpx 0; text-align: center; }
.empty-icon { width: 200rpx; height: 200rpx; margin-bottom: 32rpx; opacity: 0.45; }
.empty-title { display: block; font-size: 34rpx; font-weight: 700; color: var(--text-title); margin-bottom: 16rpx; }
.empty-desc { display: block; font-size: 28rpx; color: var(--text-secondary); margin-bottom: 40rpx; }

/* 推荐区 */
.recommendation-section { padding: 24rpx; margin-top: 16rpx; }
.section-title {
  font-size: 30rpx; font-weight: 700; margin-bottom: 20rpx;
  padding-left: 14rpx; border-left: 6rpx solid var(--brand); color: var(--text-title);
}
.recommend-scroll { white-space: nowrap; width: 100%; }
.recommend-list { display: inline-flex; gap: 16rpx; }
.recommend-item {
  width: 200rpx; flex-shrink: 0;
  background: #ffffff; border-radius: var(--radius-md);
  padding: 12rpx; border: 1rpx solid var(--border); box-shadow: none;
}
.recommend-img {
  width: 100%; height: 150rpx; border-radius: var(--radius-sm);
  margin-bottom: 8rpx; background-color: var(--bg-page);
}
.recommend-name {
  display: block; font-size: 24rpx; color: var(--text-title);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
