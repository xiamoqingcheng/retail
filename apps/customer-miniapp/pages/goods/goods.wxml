<view class="container">
  <view class="goods-header">
    <text class="header-title">商品详情</text>
  </view>

  <view class="goods-content" wx:if="{{goods}}">
    <view class="goods-image-section">
      <image class="goods-image" src="{{goods.image}}" mode="aspectFit"></image>
    </view>

    <view class="goods-info card">
      <view class="goods-name-row">
        <text class="goods-name">{{goods.name}}</text>
      </view>
      <view class="goods-price-row">
        <text class="goods-price price">¥{{goods.price}}</text>
      </view>
    </view>

    <view class="goods-location card" wx:if="{{goods.location}}">
      <view class="location-header">
        <image class="location-icon" src="/assets/icons/location.png" mode="aspectFit"></image>
        <text class="location-title">商品位置</text>
      </view>
      <text class="location-text">{{goods.location}}</text>
    </view>
  </view>

  <view class="empty-goods" wx:if="{{!goods}}">
    <image class="empty-icon" src="/assets/icons/empty.png"></image>
    <text class="empty-text">商品信息加载失败</text>
    <button class="btn-primary" bindtap="goBack">返回</button>
  </view>

  <view class="bottom-bar" wx:if="{{goods}}">
    <view class="bottom-actions">
      <button class="btn-add-cart" bindtap="addToCart">加入购物车</button>
    </view>
  </view>
</view>
