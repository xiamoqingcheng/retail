# Production environment template.
# Copy this file to .env.production on the deployment host.

VITE_USER_NODE_ENV = production
VITE_PUBLIC_PATH = /
VITE_ROUTER_MODE = hash
VITE_BUILD_COMPRESS = none
VITE_BUILD_COMPRESS_DELETE_ORIGIN_FILE = false
VITE_DROP_CONSOLE = true
VITE_PWA = true

# Empty means the built admin app calls the same-origin /api reverse proxy.
# Set a full origin only when the API is hosted separately, for example:
# VITE_API_URL = "https://api.example.com"
VITE_API_URL = ""
